# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env.local
.env.*.local

# ── Secrets & local config ─────────────────────────────────────────────────────
# Keep .env.example committed; ignore the real .env
.env
!.env.example

# ── Uploaded documents & data ─────────────────────────────────────────────────
data/uploads/
data/*.db
data/*.sqlite

# ── Qdrant local storage (when not using Docker) ──────────────────────────────
qdrant_storage/
.qdrant/

# ── Model cache (HuggingFace / sentence-transformers) ─────────────────────────
.cache/
models/
*.bin
*.safetensors
*.pt
*.pth

# ── Node / UI ──────────────────────────────────────────────────────────────────
ui/node_modules/
ui/dist/
ui/.vite/
ui/coverage/
node_modules/

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db
desktop.ini

# ── Testing & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.log

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.swp
~$*
